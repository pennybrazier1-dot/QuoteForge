# =============================================================================
# QuoteForge environment variables
# Copy to .env.local for local dev. Add the same keys in Vercel → Project → Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (public — safe in the browser; access is enforced by Row Level Security)
# From: Supabase project → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Site URL (optional for Vercel previews — auto-detected from VERCEL_URL on deploy)
# Required for production when using a custom domain, e.g. https://app.quoteforge.com
# Local dev default: http://localhost:3000
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------------------------------------
# OpenAI (server-only — never expose to the client)
# Used for AI proposal generation
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Optional. Default: gpt-4o-mini
OPENAI_MODEL=

# -----------------------------------------------------------------------------
# Resend (server-only — never expose to the client)
# Used when sending proposal emails from the app
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# Example: "Your Business Name <proposals@yourdomain.com>"
# If omitted, Resend sandbox sender is used when a business name is set
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Platform admin (server-only — temporary until role-based auth exists)
# Comma-separated login emails allowed to see /admin and the sidebar Admin link
# -----------------------------------------------------------------------------
PLATFORM_ADMIN_EMAILS=
